<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>all posts</title>
</head>
<body>
    <h1>Quora Posts</h1>
    <hr>
<% for(post of posts){%>
<div>
    <h2><%= post.username %></h2>
    <h3><%= post.content %></h2>
        <div>
            <a href="/posts/<%= post.id %>">See More</a>
            <a href="/posts/<%= post.id %>/edit">Edit</a>
            <form style="display: inline;" method="post" action="/posts/<%= post.id %>/delete?_method=DELETE">
                <button>Delete</button>
            </form>
        </div>
    <hr>
</div>
<% } %>
<div>
    <a href="/post/new">Add New Post➡️</a>
</div>
<br>
<hr>
<%- include("include/footer.ejs") %>
</body>
</html>